# LiveKit Environment Variables
# Copy this file to .env and fill in your values

# ── LiveKit Server Keys ──
# Generate with: docker run --rm livekit/generate
LIVEKIT_API_KEY=APIxxxxxxxxxxx
LIVEKIT_API_SECRET=SecretKeyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Domain Configuration ──
LIVEKIT_DOMAIN=meet.learnova.com
TURN_DOMAIN=turn.meet.learnova.com

# ── VPS Configuration ──
VPS_PUBLIC_IP=YOUR_VPS_PUBLIC_IP

# ── TURN Server Credentials ──
TURN_USER=learnova
TURN_PASSWORD=CHANGE_THIS_PASSWORD

# ── Supabase Edge Function Secrets ──
# Set these in your Supabase Dashboard > Edge Functions > Secrets
# LIVEKIT_API_KEY=<same as above>
# LIVEKIT_API_SECRET=<same as above>

# ── Frontend Environment Variables ──
# Add to your Vercel/frontend .env:
# VITE_LIVEKIT_URL=wss://meet.learnova.com
# VITE_LIVE_CLASS_PROVIDER=livekit
